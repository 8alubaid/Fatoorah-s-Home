# Copy this file to ".env" and fill in your Lean credentials.
# Get these from the Lean Application Dashboard (dev.leantech.me) after onboarding.
# NEVER commit the real .env — it contains your secret.

LEAN_ENV=sandbox            # sandbox | production
LEAN_APP_ID=your-application-id
LEAN_CLIENT_SECRET=your-client-secret
PORT=4000
