{
  "expo": {
    "name": "Fatoorah",
    "slug": "fatoorah",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fatoorah",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fatoorah.app"
    },
    "android": {
      "package": "com.fatoorah.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0C"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76d2d44a-60bc-482c-9594-d56a4cfc9eda"
      }
    }
  }
}
